<div class="page-header">
  <h1>🧾 Venda #{{venda.id}}</h1>
  <a href="/vendes" class="btn btn-sec">← Tornar</a>
</div>

<div class="fitxa-grid">
  <div class="card">
    <h3>Dades de la venda</h3>
    <dl class="dades-list">
      <dt>Client</dt><dd><a href="/clientFitxa?id={{venda.clientId}}">{{venda.clientNom}}</a></dd>
      <dt>Data</dt><dd>{{formatDate venda.sale_date}}</dd>
      <dt>Mètode pagament</dt><dd>{{venda.payment_method}}</dd>
      <dt>Total</dt><dd><strong>{{formatPrice venda.total}}</strong></dd>
    </dl>
  </div>
</div>

<div class="card">
  <h3>📋 Línies de la venda</h3>
  <table class="taula">
    <thead>
      <tr><th>Producte</th><th>Categoria</th><th>Quantitat</th><th>Preu unit.</th><th>Subtotal</th></tr>
    </thead>
    <tbody>
      {{#each linies}}
      <tr>
        <td><strong>{{productNom}}</strong></td>
        <td><span class="badge badge-categoria">{{category}}</span></td>
        <td>{{qty}}</td>
        <td>{{formatPrice unit_price}}</td>
        <td>{{formatPrice line_total}}</td>
      </tr>
      {{/each}}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4"><strong>Total venda</strong></td>
        <td><strong>{{formatPrice venda.total}}</strong></td>
      </tr>
    </tfoot>
  </table>
</div>
