<div class="page-header">
  <h1>➕ Nova venda</h1>
  <a href="/vendes" class="btn btn-sec">← Tornar</a>
</div>

{{#if (eq ../query.error "stock")}}
<div class="alerta alerta-error">❌ Error: stock insuficient per a un o més productes seleccionats.</div>
{{/if}}

<div class="card form-card">
  <form method="POST" action="/vendaCreate">
    <div class="form-grup">
      <label for="customer_id">Client <span class="obligatori">*</span></label>
      <select id="customer_id" name="customer_id" class="form-control" required>
        <option value="">-- Selecciona client --</option>
        {{#each clients}}
        <option value="{{id}}">{{name}}</option>
        {{/each}}
      </select>
    </div>

    <div class="form-row">
      <div class="form-grup">
        <label for="sale_date">Data <span class="obligatori">*</span></label>
        <input type="date" id="sale_date" name="sale_date" class="form-control" required>
      </div>
      <div class="form-grup">
        <label for="payment_method">Mètode pagament</label>
        <select id="payment_method" name="payment_method" class="form-control">
          <option value="Targeta">Targeta</option>
          <option value="Efectiu">Efectiu</option>
          <option value="Bizum">Bizum</option>
          <option value="Transferència">Transferència</option>
        </select>
      </div>
    </div>

    <h3>Línies de la venda</h3>
    <div id="linies-venda">
      <div class="linia-venda" data-linia="0">
        <select name="product_ids" class="form-control select-producte" onchange="actualitzaPreu(this)">
          <option value="">-- Selecciona producte --</option>
          {{#each productes}}
          <option value="{{id}}" data-preu="{{price}}" data-stock="{{stock}}">{{name}} ({{stock}} en stock)</option>
          {{/each}}
        </select>
        <input type="number" name="qtys" class="form-control input-qty" min="1" value="1" placeholder="Qty">
        <input type="number" name="unit_prices" class="form-control input-preu" step="0.01" placeholder="Preu">
        <span class="linia-subtotal">0,00 €</span>
        <button type="button" class="btn btn-danger btn-sm" onclick="eliminarLinia(this)">✕</button>
      </div>
    </div>

    <button type="button" class="btn btn-sec" onclick="afegirLinia()">+ Afegir producte</button>

    <div class="total-venda">
      <strong>Total: <span id="total-venda">0,00 €</span></strong>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">💾 Crear venda</button>
      <a href="/vendes" class="btn btn-sec">Cancel·lar</a>
    </div>
  </form>
</div>

<script>
const productes = {{{json productes}}};

function getProductesOptions(selectedId) {
  let opts = '<option value="">-- Selecciona producte --</option>';
  productes.forEach(p => {
    const sel = p.id == selectedId ? 'selected' : '';
    opts += `<option value="${p.id}" data-preu="${p.price}" data-stock="${p.stock}" ${sel}>${p.name} (${p.stock} en stock)</option>`;
  });
  return opts;
}

function afegirLinia() {
  const cont = document.getElementById('linies-venda');
  const div = document.createElement('div');
  div.className = 'linia-venda';
  div.innerHTML = `
    <select name="product_ids" class="form-control select-producte" onchange="actualitzaPreu(this)">
      ${getProductesOptions(null)}
    </select>
    <input type="number" name="qtys" class="form-control input-qty" min="1" value="1" placeholder="Qty" oninput="recalcula(this.closest('.linia-venda'))">
    <input type="number" name="unit_prices" class="form-control input-preu" step="0.01" placeholder="Preu" oninput="recalcula(this.closest('.linia-venda'))">
    <span class="linia-subtotal">0,00 €</span>
    <button type="button" class="btn btn-danger btn-sm" onclick="eliminarLinia(this)">✕</button>
  `;
  cont.appendChild(div);
}

function eliminarLinia(btn) {
  const linies = document.querySelectorAll('.linia-venda');
  if (linies.length <= 1) return;
  btn.closest('.linia-venda').remove();
  actualitzaTotal();
}

function actualitzaPreu(sel) {
  const opt = sel.options[sel.selectedIndex];
  const preu = opt.dataset.preu || '';
  const linia = sel.closest('.linia-venda');
  linia.querySelector('.input-preu').value = preu;
  recalcula(linia);
}

function recalcula(linia) {
  const qty = parseFloat(linia.querySelector('.input-qty').value) || 0;
  const preu = parseFloat(linia.querySelector('.input-preu').value) || 0;
  const sub = (qty * preu).toFixed(2).replace('.', ',') + ' €';
  linia.querySelector('.linia-subtotal').textContent = sub;
  actualitzaTotal();
}

function actualitzaTotal() {
  let total = 0;
  document.querySelectorAll('.linia-venda').forEach(l => {
    const qty = parseFloat(l.querySelector('.input-qty').value) || 0;
    const preu = parseFloat(l.querySelector('.input-preu').value) || 0;
    total += qty * preu;
  });
  document.getElementById('total-venda').textContent = total.toFixed(2).replace('.', ',') + ' €';
}

// Inicialitza primera linia
document.querySelector('.input-qty').addEventListener('input', function() {
  recalcula(this.closest('.linia-venda'));
});
document.querySelector('.input-preu').addEventListener('input', function() {
  recalcula(this.closest('.linia-venda'));
});

// Data per defecte = avui
document.getElementById('sale_date').valueAsDate = new Date();
</script>
