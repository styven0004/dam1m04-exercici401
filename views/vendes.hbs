<div class="page-header">
  <h1>🛒 Vendes</h1>
  <a href="/vendaAfegir" class="btn btn-primary">+ Nova venda</a>
</div>

<div class="filtres-bar">
  <form method="GET" action="/vendes" class="cerca-form">
    <input type="text" name="cerca" value="{{cerca}}" placeholder="Cerca per client o mètode de pagament..." class="input-cerca">
    <button type="submit" class="btn btn-primary">Cercar</button>
    {{#if cerca}}<a href="/vendes" class="btn btn-sec">✕ Netejar</a>{{/if}}
  </form>
</div>

<p class="resum">{{total}} venda(es) trobada(es)</p>

<div class="card">
  <table class="taula">
    <thead>
      <tr>
        <th>#</th>
        <th>Data</th>
        <th>Client</th>
        <th>Pagament</th>
        <th>Total</th>
        <th>Accions</th>
      </tr>
    </thead>
    <tbody>
      {{#each vendes}}
      <tr>
        <td>#{{id}}</td>
        <td>{{formatDate sale_date}}</td>
        <td><a href="/clientFitxa?id={{clientId}}">{{clientNom}}</a></td>
        <td><span class="badge badge-pagament">{{payment_method}}</span></td>
        <td><strong>{{formatPrice total}}</strong></td>
        <td><a href="/vendaDetall?id={{id}}" class="btn btn-sm btn-info">👁 Veure</a></td>
      </tr>
      {{else}}
      <tr><td colspan="6" class="buit">No s'han trobat vendes</td></tr>
      {{/each}}
    </tbody>
  </table>
</div>

{{> paginacio}}
