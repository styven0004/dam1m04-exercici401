<div class="flex-between mb-24">
  <div>
    <h2 style="font-family: 'Rajdhani', sans-serif; font-size: 22px; margin-bottom: 4px;">
      {{client.name}}
      {{#if client.esVip}}<span class="badge badge-warning" style="font-size: 14px;">⭐ VIP</span>{{/if}}
    </h2>
    <p class="text-muted" style="font-size: 14px;">Client #{{client.id}} · Registrat el {{client.created_at}}</p>
  </div>
  <div style="display: flex; gap: 8px;">
    <a href="/clients/editar/{{client.id}}" class="btn btn-secondary">✏️ Editar</a>
    <a href="/clients" class="btn btn-ghost">← Tornar</a>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px;">
  <div>
    <div class="card mb-16">
      <div class="card-header">
        <span class="card-title">👤 Dades del client</span>
      </div>
      <div class="card-body">
        <div style="display: flex; flex-direction: column; gap: 14px;">
          <div>
            <div class="text-muted" style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 3px;">Email</div>
            <div>{{client.email}}</div>
          </div>
          <div>
            <div class="text-muted" style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 3px;">Telèfon</div>
            <div>{{client.phone}}</div>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <span class="card-title">📈 Resum d'activitat</span>
      </div>
      <div class="card-body">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
          <div style="text-align: center; border-right: 1px solid var(--border-color); padding-right: 6px;">
            <div style="font-family: 'Rajdhani', sans-serif; font-size: 24px; font-weight: 700;">{{client.num_compres}}</div>
            <div class="text-muted" style="font-size: 12px;">Compres</div>
          </div>
          <div style="text-align: center;">
            <div style="font-family: 'Rajdhani', sans-serif; font-size: 24px; font-weight: 700; color: var(--accent);">{{client.total_gastat}}€</div>
            <div class="text-muted" style="font-size: 12px;">Total gastat</div>
          </div>
          <div style="text-align: center; grid-column: 1/-1;">
            <div style="font-family: 'Rajdhani', sans-serif; font-size: 24px; font-weight: 700;">{{client.ticket_mig}}€</div>
            <div class="text-muted" style="font-size: 12px;">Ticket mitjà</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <span class="card-title">🧾 Últimes 10 compres</span>
    </div>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Data</th>
            <th>Pagament</th>
            <th>Total</th>
            <th>Accions</th>
          </tr>
        </thead>
        <tbody>
          {{#each historial}}
          <tr>
            <td class="text-muted">#{{this.id}}</td>
            <td>{{this.sale_date}}</td>
            <td><span class="badge badge-info">{{this.payment_method}}</span></td>
            <td class="fw-bold">{{this.total}}€</td>
            <td><a href="/vendes/detall/{{this.id}}" class="btn btn-ghost btn-sm">👁 Veure</a></td>
          </tr>
          {{else}}
          <tr>
            <td colspan="5">
              <div class="empty-state">
                <div class="empty-icon">🛒</div>
                <p>Sense compres registrades</p>
              </div>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>