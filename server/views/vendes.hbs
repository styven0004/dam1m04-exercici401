<div class="flex-between mb-24">
  <div>
    <h2 style="font-family: 'Rajdhani', sans-serif; font-size: 22px; margin-bottom: 4px;">Vendes</h2>
    <p class="text-muted" style="font-size: 14px;">{{total}} vendes registrades</p>
  </div>
  <a href="/accions/vendes/afegir" class="btn btn-primary">🛒 Nova venda</a>
</div>

<div class="card mb-24">
  <div class="card-body" style="padding: 16px 22px;">
    <form method="GET" action="/vendes" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
      <input
        type="text"
        name="cerca"
        class="form-control"
        placeholder="🔍 Cerca per client..."
        value="{{cerca}}"
        style="max-width: 280px;"
      >
      <button type="submit" class="btn btn-secondary">Cercar</button>
      {{#if cerca}}
        <a href="/vendes" class="btn btn-ghost">✕ Netejar</a>
      {{/if}}
    </form>
  </div>
</div>

<div class="card">
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Data</th>
          <th>Client</th>
          <th>Pagament</th>
          <th>Total</th>
          <th>Accions</th>
        </tr>
      </thead>
      <tbody>
        {{#each vendes}}
        <tr>
          <td class="text-muted">#{{this.id}}</td>
          <td>{{this.sale_date}}</td>
          <td class="fw-bold">{{this.client_name}}</td>
          <td><span class="badge badge-info">{{this.payment_method}}</span></td>
          <td class="fw-bold">{{this.total}}€</td>
          <td>
            <a href="/vendes/detall/{{this.id}}" class="btn btn-ghost btn-sm">👁 Veure</a>
          </td>
        </tr>
        {{else}}
        <tr>
          <td colspan="6">
            <div class="empty-state">
              <div class="empty-icon">💰</div>
              <p>No s'han trobat vendes{{#if cerca}} per "{{cerca}}"{{/if}}</p>
            </div>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

{{#if totalPagines}}
<div class="paginacio">
  {{#if paginaAnterior}}
    <a href="/vendes?pagina={{paginaAnterior}}{{#if cerca}}&cerca={{cerca}}{{/if}}">‹</a>
  {{/if}}
  {{#each pagines}}
    {{#if this.actual}}
      <span class="actual">{{this.num}}</span>
    {{else}}
      <a href="/vendes?pagina={{this.num}}{{#if ../cerca}}&cerca={{../cerca}}{{/if}}">{{this.num}}</a>
    {{/if}}
  {{/each}}
  {{#if paginaSeguent}}
    <a href="/vendes?pagina={{paginaSeguent}}{{#if cerca}}&cerca={{cerca}}{{/if}}">›</a>
  {{/if}}
</div>
{{/if}}