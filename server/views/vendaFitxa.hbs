<div class="flex-between mb-24">
  <div>
    <h2 style="font-family: 'Rajdhani', sans-serif; font-size: 22px; margin-bottom: 4px;">Venda #{{venda.id}}</h2>
    <p class="text-muted" style="font-size: 14px;">{{venda.sale_date}}</p>
  </div>
  <a href="/vendes" class="btn btn-ghost">← Tornar</a>
</div>

<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px;">
  <div class="card" style="align-self: start;">
    <div class="card-header">
      <span class="card-title">📋 Detalls</span>
    </div>
    <div class="card-body">
      <div style="display: flex; flex-direction: column; gap: 14px;">
        <div>
          <div class="text-muted" style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 3px;">Client</div>
          <a href="/clients/detall/{{venda.customer_id}}" style="color: var(--accent); text-decoration: none; font-weight: 600;">{{venda.client_name}}</a>
        </div>
        <div>
          <div class="text-muted" style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 3px;">Mètode de pagament</div>
          <div><span class="badge badge-info">{{venda.payment_method}}</span></div>
        </div>
        <div style="border-top: 1px solid var(--border-color); padding-top: 14px;">
          <div class="text-muted" style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 3px;">Total</div>
          <div style="font-family: 'Rajdhani', sans-serif; font-size: 32px; font-weight: 700; color: var(--accent);">{{venda.total}}€</div>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <span class="card-title">🎮 Productes comprats</span>
    </div>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Producte</th>
            <th>Preu unit.</th>
            <th>Quantitat</th>
            <th>Subtotal</th>
          </tr>
        </thead>
        <tbody>
          {{#each linies}}
          <tr>
            <td class="fw-bold">{{this.product_name}}</td>
            <td>{{this.unit_price}}€</td>
            <td>×{{this.qty}}</td>
            <td class="fw-bold">{{this.line_total}}€</td>
          </tr>
          {{else}}
          <tr>
            <td colspan="4" class="empty-state">Sense línies</td>
          </tr>
          {{/each}}
        </tbody>
        <tfoot>
          <tr style="border-top: 2px solid var(--border-color);">
            <td colspan="3" class="fw-bold text-right" style="padding: 12px 16px;">TOTAL</td>
            <td class="fw-bold" style="padding: 12px 16px; color: var(--accent); font-size: 16px;">{{venda.total}}€</td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>