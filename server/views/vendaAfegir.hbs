<!-- NOVA VENDA -->
<div class="flex-between mb-24">
  <div>
    <h2 style="font-family: 'Rajdhani', sans-serif; font-size: 22px; margin-bottom: 4px;">🛒 Nova Venda</h2>
    <p class="text-muted" style="font-size: 14px;">Registra una nova venda i les seves línies</p>
  </div>
  <a href="/vendes" class="btn btn-ghost">← Tornar</a>
</div>

<form id="formVenda" method="POST" action="/create" novalidate>
  <input type="hidden" name="taula" value="vendes">

  <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px; align-items: start;">
    <!-- Dades generals -->
    <div class="card">
      <div class="card-header"><span class="card-title">📋 Dades generals</span></div>
      <div class="card-body">
        <div class="form-group">
          <label class="form-label" for="customer_id">Client *</label>
          <select id="customer_id" name="customer_id" class="form-control" required>
            <option value="">— Selecciona client —</option>
            {{#each clients}}
              <option value="{{this.id}}">{{this.name}}</option>
            {{/each}}
          </select>
          <div class="error-msg" id="err-customer_id">Has de seleccionar un client.</div>
        </div>

        <div class="form-group">
          <label class="form-label" for="payment_method">Mètode de pagament</label>
          <select id="payment_method" name="payment_method" class="form-control">
            <option value="Targeta">Targeta</option>
            <option value="Efectiu">Efectiu</option>
            <option value="Bizum">Bizum</option>
            <option value="Transferència">Transferència</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="sale_date">Data de venda</label>
          <input type="datetime-local" id="sale_date" name="sale_date" class="form-control" value="{{dataAvui}}">
        </div>

        <div style="border-top: 1px solid var(--border-color); padding-top: 16px;">
          <div class="text-muted" style="font-size: 12px; margin-bottom: 4px;">Total calculat</div>
          <div id="totalCalculat" style="font-family: 'Rajdhani', sans-serif; font-size: 32px; font-weight: 700; color: var(--accent);">0.00€</div>
          <input type="hidden" name="total" id="totalHidden" value="0">
        </div>
      </div>
    </div>

    <!-- Línies de venda -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">🎮 Línies de venda</span>
        <button type="button" class="btn btn-secondary btn-sm" onclick="afegirLinia()">➕ Afegir línia</button>
      </div>
      <div class="card-body">
        <div id="linies">
          <!-- Les línies s'afegiran dinàmicament -->
        </div>
        <div id="errLinies" class="error-msg">Has d'afegir almenys un producte.</div>

        <div class="form-actions" style="margin-top: 24px;">
          <button type="submit" class="btn btn-primary">💾 Crear venda</button>
          <a href="/vendes" class="btn btn-ghost">Cancel·lar</a>
        </div>
      </div>
    </div>
  </div>
</form>

<script>
  const productes = {{{productesJSON}}};
  let lineaIndex = 0;

  function afegirLinia() {
    const div = document.createElement('div');
    div.className = 'linia-venda';
    div.dataset.idx = lineaIndex;
    div.style.cssText = 'display:grid; grid-template-columns: 2fr 1fr 1fr auto; gap: 10px; align-items: end; margin-bottom: 12px; padding: 12px; background: var(--bg-primary); border-radius: 8px; border: 1px solid var(--border-color);';

    div.innerHTML = `
      <div class="form-group" style="margin:0;">
        <label class="form-label">Producte</label>
        <select name="linies[${lineaIndex}][product_id]" class="form-control sel-producte" onchange="actualitzarPreu(this, ${lineaIndex})" required>
          <option value="">— Selecciona —</option>
          ${productes.map(p => `<option value="${p.id}" data-preu="${p.price}" data-stock="${p.stock}">${p.name} (${p.price}€)</option>`).join('')}
        </select>
      </div>
      <div class="form-group" style="margin:0;">
        <label class="form-label">Preu unit.</label>
        <input type="number" name="linies[${lineaIndex}][unit_price]" id="preu_${lineaIndex}" class="form-control" value="0" step="0.01" min="0" readonly style="background: var(--bg-primary);">
      </div>
      <div class="form-group" style="margin:0;">
        <label class="form-label">Quantitat</label>
        <input type="number" name="linies[${lineaIndex}][qty]" id="qty_${lineaIndex}" class="form-control" value="1" min="1" oninput="recalcularTotal()">
      </div>
      <button type="button" onclick="eliminarLinia(this)" style="margin-bottom: 1px;" class="btn btn-danger btn-sm">✕</button>
      <input type="hidden" name="linies[${lineaIndex}][line_total]" id="total_${lineaIndex}" value="0">
    `;

    document.getElementById('linies').appendChild(div);
    lineaIndex++;
    recalcularTotal();
  }

  function actualitzarPreu(sel, idx) {
    const opt = sel.options[sel.selectedIndex];
    const preu = parseFloat(opt.dataset.preu) || 0;
    document.getElementById('preu_' + idx).value = preu.toFixed(2);
    recalcularTotal();
  }

  function eliminarLinia(btn) {
    btn.closest('.linia-venda').remove();
    recalcularTotal();
  }

  function recalcularTotal() {
    let total = 0;
    document.querySelectorAll('.linia-venda').forEach(div => {
      const idx = div.dataset.idx;
      const preu = parseFloat(document.getElementById('preu_' + idx)?.value) || 0;
      const qty = parseInt(document.getElementById('qty_' + idx)?.value) || 0;
      const subtotal = preu * qty;
      const totalInput = document.getElementById('total_' + idx);
      if (totalInput) totalInput.value = subtotal.toFixed(2);
      total += subtotal;
    });
    document.getElementById('totalCalculat').textContent = total.toFixed(2) + '€';
    document.getElementById('totalHidden').value = total.toFixed(2);
  }

  document.getElementById('formVenda').addEventListener('submit', function(e) {
    e.preventDefault();
    let valid = true;

    if (!document.getElementById('customer_id').value) {
      document.getElementById('customer_id').classList.add('error');
      document.getElementById('err-customer_id').classList.add('visible');
      valid = false;
    }

    const linies = document.querySelectorAll('.linia-venda');
    if (linies.length === 0) {
      document.getElementById('errLinies').classList.add('visible');
      valid = false;
    } else {
      document.getElementById('errLinies').classList.remove('visible');
    }

    if (valid) this.submit();
  });

  // Afegir una línia inicial
  afegirLinia();
</script>
