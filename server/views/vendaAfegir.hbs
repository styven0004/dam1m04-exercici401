<div class="flex-between mb-24">
  <div>
    <h2 style="font-family: 'Rajdhani', sans-serif; font-size: 22px; margin-bottom: 4px;">🛒 Nova Venda</h2>
    <p class="text-muted" style="font-size: 14px;">Registra una nova venda i les seves línies</p>
  </div>
  <a href="/vendes" class="btn btn-ghost">← Tornar</a>
</div>

<form id="formVenda" method="POST" action="/accions/vendes/afegir" novalidate>
  <input type="hidden" name="taula" value="vendes">

  <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px; align-items: start;">
    <div class="card">
      <div class="card-header"><span class="card-title">📋 Dades generals</span></div>
      <div class="card-body">
        <div class="form-group">
          <label class="form-label" for="customer_id">Client *</label>
          <select id="customer_id" name="customer_id" class="form-control" required>
            <option value="">— Selecciona client —</option>
            {{#each clients}}
              <option value="{{this.id}}">{{this.name}}</option>
            {{/each}}
          </select>
          <div class="error-msg" id="err-customer_id">Has de seleccionar un client.</div>
        </div>

        <div class="form-group">
          <label class="form-label" for="payment_method">Mètode de pagament</label>
          <select id="payment_method" name="payment_method" class="form-control">
            <option value="Efectiu">💵 Efectiu</option>
            <option value="Targeta" selected>💳 Targeta</option>
            <option value="Transferència">🏦 Transferència</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="sale_date">Data i hora</label>
          <input type="datetime-local" id="sale_date" name="sale_date" class="form-control" value="{{dataAvui}}">
        </div>

        <div style="border-top: 1px solid var(--border-color); margin-top: 20px; padding-top: 16px; text-align: center;">
          <div class="text-muted" style="font-size: 12px; text-transform: uppercase; margin-bottom: 4px;">Total Venda</div>
          <div id="totalCalculat" style="font-family: 'Rajdhani', sans-serif; font-size: 36px; font-weight: 700; color: var(--accent);">0.00€</div>
          <input type="hidden" id="totalHidden" name="total" value="0.00">
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <span class="card-title">🎮 Línies de la venda</span>
        <button type="button" class="btn btn-secondary btn-sm" onclick="afegirLinia()">➕ Afegir línia</button>
      </div>
      <div class="card-body" id="contenidorLinies" style="display: flex; flex-direction: column; gap: 12px;">
        <div class="error-msg" id="errLinies" style="margin-bottom: 10px;">Has d'afegir com a mínim un producte amb quantitat vàlida.</div>
      </div>
      <div class="card-footer" style="display: flex; justify-content: flex-end; gap: 10px; border-top: 1px solid var(--border-color); padding: 16px 22px;">
        <a href="/vendes" class="btn btn-ghost">Cancel·lar</a>
        <button type="submit" class="btn btn-primary">💾 Registrar Venda</button>
      </div>
    </div>
  </div>
</form>

<script>
  const productes = {{{productesJSON}}};
  let liniaIdx = 0;

  function afegirLinia() {
    document.getElementById('errLinies').classList.remove('visible');
    liniaIdx++;

    let options = '<option value="">— Selecciona producte —</option>';
    productes.forEach(p => {
      options += `<option value="${p.id}">[Stock: ${p.stock}] ${p.name} — ${p.price}€</option>`;
    });

    const div = document.createElement('div');
    div.className = 'linia-venda';
    div.id = 'linia_' + liniaIdx;
    div.dataset.idx = liniaIdx;
    div.style = 'display: grid; grid-template-columns: 3fr 1fr 1fr 1fr auto; gap: 10px; align-items: center; border-bottom: 1px dashed var(--border-color); padding-bottom: 12px;';

    div.innerHTML = `
      <div>
        <select name="lines[${liniaIdx}][product_id]" id="prod_${liniaIdx}" class="form-control" onchange="seleccionarProducte(${liniaIdx})" required>
          ${options}
        </select>
      </div>
      <div>
        <input type="number" name="lines[${liniaIdx}][price]" id="preu_${liniaIdx}" class="form-control" placeholder="0.00" readonly style="background: #f4f4f6;">
      </div>
      <div>
        <input type="number" name="lines[${liniaIdx}][qty]" id="qty_${liniaIdx}" class="form-control" value="1" min="1" oninput="canviQuantitat(${liniaIdx})" required>
      </div>
      <div>
        <input type="text" id="total_${liniaIdx}" class="form-control" value="0.00" readonly style="background: #f4f4f6; font-weight: 600;">
      </div>
      <div>
        <button type="button" class="btn btn-danger btn-sm" onclick="eliminarLinia(this)">🗑</button>
      </div>
    `;

    document.getElementById('contenidorLinies').appendChild(div);
  }

  function seleccionarProducte(idx) {
    const sel = document.getElementById('prod_' + idx);
    const pId = sel.value;
    const pData = productes.find(p => p.id == pId);

    const priceInput = document.getElementById('preu_' + idx);
    const qtyInput = document.getElementById('qty_' + idx);

    if (pData) {
      priceInput.value = pData.price;
      qtyInput.max = pData.stock;
      if (parseInt(qtyInput.value) > pData.stock) qtyInput.value = pData.stock;
    } else {
      priceInput.value = '';
      qtyInput.removeAttribute('max');
    }
    recalcularTotal();
  }

  function canviQuantitat(idx) {
    const qtyInput = document.getElementById('qty_' + idx);
    const sel = document.getElementById('prod_' + idx);
    const pData = productes.find(p => p.id == sel.value);

    if (pData && parseInt(qtyInput.value) > pData.stock) {
      alert('No hi ha prou stock. Stock màxim: ' + pData.stock);
      qtyInput.value = pData.stock;
    }
    recalcularTotal();
  }

  function eliminarLinia(btn) {
    btn.closest('.linia-venda').remove();
    recalcularTotal();
  }

  function recalcularTotal() {
    let total = 0;
    document.querySelectorAll('.linia-venda').forEach(div => {
      const idx = div.dataset.idx;
      const preu = parseFloat(document.getElementById('preu_' + idx)?.value) || 0;
      const qty = parseInt(document.getElementById('qty_' + idx)?.value) || 0;
      const subtotal = preu * qty;
      const totalInput = document.getElementById('total_' + idx);
      if (totalInput) totalInput.value = subtotal.toFixed(2);
      total += subtotal;
    });
    document.getElementById('totalCalculat').textContent = total.toFixed(2) + '€';
    document.getElementById('totalHidden').value = total.toFixed(2);
  }

  document.getElementById('formVenda').addEventListener('submit', function(e) {
    e.preventDefault();
    let valid = true;

    if (!document.getElementById('customer_id').value) {
      document.getElementById('customer_id').classList.add('error');
      document.getElementById('err-customer_id').classList.add('visible');
      valid = false;
    }

    const linies = document.querySelectorAll('.linia-venda');
    if (linies.length === 0) {
      document.getElementById('errLinies').classList.add('visible');
      valid = false;
    } else {
      linies.forEach(div => {
        const idx = div.dataset.idx;
        const prod = document.getElementById('prod_' + idx);
        const qty = document.getElementById('qty_' + idx);
        if (!prod.value || !qty.value || parseInt(qty.value) <= 0) {
          prod.classList.add('error');
          qty.classList.add('error');
          valid = false;
        }
      });
    }

    if (valid) this.submit();
  });

  document.getElementById('customer_id').addEventListener('change', function() {
    this.classList.remove('error');
    document.getElementById('err-customer_id').classList.remove('visible');
  });

  if (document.querySelectorAll('.linia-venda').length === 0) {
    afegirLinia();
  }
</script>