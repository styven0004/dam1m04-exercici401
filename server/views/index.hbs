<!-- DASHBOARD -->
<div class="tabs">
  <button class="tab-btn actiu" onclick="canviarPestanya('kpi', this)">📊 KPIs</button>
  <button class="tab-btn" onclick="canviarPestanya('llistats', this)">📋 Llistats</button>
</div>

<!-- Pestanya KPI -->
<div id="tab-kpi" class="tab-content actiu">
  <div class="flex-between mb-24">
    <h2 style="font-family: 'Rajdhani', sans-serif; font-size: 18px;">Resum executiu</h2>
    <button class="btn btn-toggle" id="btnCompacte" onclick="toggleCompacte()">⊟ Mode compacte</button>
  </div>

  <div class="kpi-grid" id="kpiGrid">
    <div class="kpi-card">
      <div class="kpi-icon">💶</div>
      <div class="kpi-label">Vendes avui</div>
      <div class="kpi-value">{{vendesAvui}}€</div>
      <div class="kpi-sub">{{numVendesAvui}} comandes</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">📅</div>
      <div class="kpi-label">Vendes del mes</div>
      <div class="kpi-value">{{vendesMes}}€</div>
      <div class="kpi-sub">{{numVendesMes}} comandes</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">📦</div>
      <div class="kpi-label">Comandes avui</div>
      <div class="kpi-value">{{numVendesAvui}}</div>
      <div class="kpi-sub">Comandes registrades</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">⚠️</div>
      <div class="kpi-label">Stock baix</div>
      <div class="kpi-value">{{productesBaixStock}}</div>
      <div class="kpi-sub">Productes sota mínim</div>
    </div>
  </div>
</div>

<!-- Pestanya Llistats -->
<div id="tab-llistats" class="tab-content">
  <div class="flex-between mb-24">
    <h2 style="font-family: 'Rajdhani', sans-serif; font-size: 18px;">Llistats ràpids</h2>
    <button class="btn btn-toggle" id="btnColors" onclick="toggleColors()">🎨 Codi de colors</button>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
    <!-- Últimes vendes -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">🧾 Últimes 5 vendes</span>
        <a href="/vendes" class="btn btn-ghost btn-sm">Veure totes</a>
      </div>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Data</th>
              <th>Client</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {{#each ultVendes}}
            <tr>
              <td>{{this.data}}</td>
              <td>{{this.client}}</td>
              <td class="fw-bold">{{this.total}}€</td>
            </tr>
            {{else}}
            <tr><td colspan="3" class="empty-state">Sense vendes</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Top 5 productes -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">🏆 Top 5 productes</span>
        <a href="/productes" class="btn btn-ghost btn-sm">Veure tots</a>
      </div>
      <div class="table-wrapper" id="topProductesTable">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Producte</th>
              <th>Stock</th>
              <th>Venuts</th>
            </tr>
          </thead>
          <tbody>
            {{#each topProductes}}
            <tr data-stock="{{this.stock}}" data-stock-max="50">
              <td>{{plusOne @index}}</td>
              <td>{{this.name}}</td>
              <td>{{this.stock}}</td>
              <td class="fw-bold">{{this.total_venuts}}</td>
            </tr>
            {{else}}
            <tr><td colspan="4" class="empty-state">Sense dades</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  function canviarPestanya(id, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('actiu'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('actiu'));
    document.getElementById('tab-' + id).classList.add('actiu');
    btn.classList.add('actiu');
  }

  // Toggle compacte KPI
  let modeCompacte = false;
  function toggleCompacte() {
    modeCompacte = !modeCompacte;
    const grid = document.getElementById('kpiGrid');
    const btn = document.getElementById('btnCompacte');
    grid.querySelectorAll('.kpi-card').forEach(c => c.classList.toggle('compact', modeCompacte));
    btn.classList.toggle('actiu', modeCompacte);
    btn.textContent = modeCompacte ? '⊞ Mode complet' : '⊟ Mode compacte';
  }

  // Toggle codi colors stock
  let colorsActiu = false;
  function toggleColors() {
    colorsActiu = !colorsActiu;
    const btn = document.getElementById('btnColors');
    btn.classList.toggle('actiu', colorsActiu);
    btn.textContent = colorsActiu ? '🎨 Colors actius' : '🎨 Codi de colors';

    document.querySelectorAll('#topProductesTable tbody tr').forEach(row => {
      row.classList.remove('stock-ok', 'stock-baix', 'stock-critic');
      if (colorsActiu) {
        const stock = parseInt(row.dataset.stock) || 0;
        if (stock <= 5) row.classList.add('stock-critic');
        else if (stock <= 15) row.classList.add('stock-baix');
        else row.classList.add('stock-ok');
      }
    });
  }
</script>
